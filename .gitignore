# Secrets and certs
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx

# Keycloak deployment state (TLS, themes, .env.kc) — generated on the VM
stack/keycloak/tls/
stack/keycloak/themes/
stack/keycloak/.env.kc

# Logs
logs/
*.log

# Python build / cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
.ruff_cache/
.mypy_cache/

# Virtualenvs
.venv/
venv/
ENV/

# Test / report dumps
*.xml
*_results.txt
out*.txt
failures*.txt
pytest_*.txt
coverage_out.txt
summary.txt

# Packaging archives
*.tar.gz
*.tgz
*.zip

# LaTeX build by-products (sources under docs/ stay trackable)
*.aux
*.toc
*.synctex.gz
*.fls
*.fdb_latexmk

# OS / editor state
.DS_Store
Thumbs.db
.vscode/
.idea/
.claude/

# Sensitive mock data
tests/fixtures/crypto_config_mock/

# Node deps (tooling scripts only — no JS app in this repo)
node_modules/
package.json
package-lock.json

# Local-only directories that must never reach the repo
dapp/
.git.backup-*/

# Windows binaries
*.exe

# Sub-repository for custom redirect links
pxtly-links/

