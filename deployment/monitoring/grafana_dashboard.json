{
  "uid": "rwa-ops-hub",
  "title": "RWA Operational Intelligence Hub",
  "tags": ["rwa", "blockchain", "enterprise", "production"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "weekStart": "",
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [

    {
      "id": 1,
      "title": "Services Online",
      "description": "Number of Prometheus targets currently UP",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "sum(up)",
        "legendFormat": "Online",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "Services Online",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#F2495C", "value": null },
            { "color": "#FF9830", "value": 5 },
            { "color": "#00D9FF", "value": 8 }
          ]},
          "custom": {}
        },
        "overrides": []
      }
    },

    {
      "id": 2,
      "title": "API Throughput",
      "description": "Total HTTP request rate across all services",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "sum(rate(http_requests_total[2m]))",
        "legendFormat": "req/s",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "displayName": "API Throughput",
          "color": { "mode": "fixed", "fixedColor": "#00A5FF" },
          "custom": {}
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "title": "Latency p95",
      "description": "95th percentile HTTP response latency",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[2m])) by (le))",
        "legendFormat": "p95",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "displayName": "Latency p95",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#00D9FF", "value": null },
            { "color": "#FF9830", "value": 0.5 },
            { "color": "#F2495C", "value": 1.5 }
          ]},
          "custom": {}
        },
        "overrides": []
      }
    },

    {
      "id": 4,
      "title": "Error Rate",
      "description": "Percentage of 4xx/5xx responses over total requests",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "sum(rate(http_requests_total{status=~\"4xx|5xx\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 0.001) * 100",
        "legendFormat": "errors %",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "displayName": "Error Rate",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#00D9FF", "value": null },
            { "color": "#FF9830", "value": 1 },
            { "color": "#F2495C", "value": 5 }
          ]},
          "custom": {}
        },
        "overrides": []
      }
    },

    {
      "id": 5,
      "title": "CPU Usage",
      "description": "Average CPU utilisation across all cores",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
        "legendFormat": "CPU %",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "displayName": "CPU",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#00D9FF", "value": null },
            { "color": "#FF9830", "value": 70 },
            { "color": "#F2495C", "value": 90 }
          ]},
          "custom": {}
        },
        "overrides": []
      }
    },

    {
      "id": 6,
      "title": "Memory Usage",
      "description": "RAM utilisation as a percentage of total available",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "Mem %",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "displayName": "Memory",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#00D9FF", "value": null },
            { "color": "#FF9830", "value": 75 },
            { "color": "#F2495C", "value": 90 }
          ]},
          "custom": {}
        },
        "overrides": []
      }
    },

    {
      "id": 7,
      "title": "Disk Used",
      "description": "Root filesystem usage percentage",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} * 100)",
        "legendFormat": "Disk %",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 0, "y": 4, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "displayName": "Disk",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#00D9FF", "value": null },
            { "color": "#FF9830", "value": 70 },
            { "color": "#F2495C", "value": 85 }
          ]},
          "custom": {}
        },
        "overrides": []
      }
    },

    {
      "id": 8,
      "title": "Celery Workers",
      "description": "Number of active Celery worker processes",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "celery_workers_up",
        "legendFormat": "Workers",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 4, "y": 4, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "Celery Workers",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#F2495C", "value": null },
            { "color": "#00A5FF", "value": 1 }
          ]},
          "custom": {}
        },
        "overrides": []
      }
    },

    {
      "id": 9,
      "title": "Active Tasks",
      "description": "Celery tasks currently being processed",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "celery_tasks_active",
        "legendFormat": "Active",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 8, "y": 4, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "Active Tasks",
          "color": { "mode": "fixed", "fixedColor": "#00D9FF" },
          "custom": {}
        },
        "overrides": []
      }
    },

    {
      "id": 10,
      "title": "Redis Hit Rate",
      "description": "Cache key hit ratio — higher is better",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "redis_keyspace_hits_total / clamp_min(redis_keyspace_hits_total + redis_keyspace_misses_total, 1) * 100",
        "legendFormat": "Hit %",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 12, "y": 4, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "displayName": "Redis Hit Rate",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#F2495C", "value": null },
            { "color": "#FF9830", "value": 70 },
            { "color": "#00D9FF", "value": 90 }
          ]},
          "custom": {}
        },
        "overrides": []
      }
    },

    {
      "id": 11,
      "title": "Latency p99",
      "description": "99th percentile HTTP response latency",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[2m])) by (le))",
        "legendFormat": "p99",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 16, "y": 4, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "displayName": "Latency p99",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#00D9FF", "value": null },
            { "color": "#FF9830", "value": 1 },
            { "color": "#F2495C", "value": 2 }
          ]},
          "custom": {}
        },
        "overrides": []
      }
    },

    {
      "id": 12,
      "title": "Redis Clients",
      "description": "Number of connected Redis clients",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "redis_connected_clients",
        "legendFormat": "Clients",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 20, "y": 4, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "Redis Clients",
          "color": { "mode": "fixed", "fixedColor": "#00A5FF" },
          "custom": {}
        },
        "overrides": []
      }
    },

    {
      "id": 200,
      "title": "SERVICE AVAILABILITY",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 1 },
      "panels": []
    },

    {
      "id": 20,
      "title": "Service Uptime — State Timeline",
      "description": "Real-time UP/DOWN status for all platform services over the selected time window",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "up{job=\"rwa-api\"}", "legendFormat": "RWA API", "refId": "A", "instant": false, "range": true },
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "up{job=\"postgres\"}", "legendFormat": "PostgreSQL", "refId": "B", "instant": false, "range": true },
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "up{job=\"redis\"}", "legendFormat": "Redis", "refId": "C", "instant": false, "range": true },
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "up{job=\"node-exporter\"}", "legendFormat": "Node Exporter", "refId": "D", "instant": false, "range": true },
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "up{job=\"fabric-peer-bnp\"}", "legendFormat": "Fabric Peer — BNP", "refId": "E", "instant": false, "range": true },
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "up{job=\"fabric-peer-amf\"}", "legendFormat": "Fabric Peer — AMF", "refId": "F", "instant": false, "range": true },
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "up{job=\"couchdb-bnp\"}", "legendFormat": "CouchDB — BNP", "refId": "G", "instant": false, "range": true },
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "up{job=\"couchdb-amf\"}", "legendFormat": "CouchDB — AMF", "refId": "H", "instant": false, "range": true },
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "up{job=\"celery\"}", "legendFormat": "Celery", "refId": "I", "instant": false, "range": true },
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "up{job=\"prometheus\"}", "legendFormat": "Prometheus", "refId": "J", "instant": false, "range": true }
      ],
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 7 },
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "alignValue": "center",
        "rowHeight": 0.85,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#F2495C", "value": null },
            { "color": "#00D9FF", "value": 1 }
          ]},
          "mappings": [{ "type": "value", "options": {
            "0": { "text": "DOWN", "color": "#F2495C", "index": 0 },
            "1": { "text": "UP",   "color": "#00D9FF", "index": 1 }
          }}],
          "custom": { "lineWidth": 0, "fillOpacity": 85 }
        },
        "overrides": []
      }
    },

    {
      "id": 201,
      "title": "API GATEWAY",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 1 },
      "panels": []
    },

    {
      "id": 30,
      "title": "Request Rate — All Services",
      "description": "Total inbound HTTP requests per second grouped by status class",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
        "expr": "sum by(status) (rate(http_requests_total[2m]))",
        "legendFormat": "HTTP {{status}}",
        "refId": "A", "instant": false, "range": true
      }],
      "gridPos": { "x": 0, "y": 17, "w": 14, "h": 9 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "last"], "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 14,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#00D9FF", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "HTTP 2xx" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00D9FF" } }] },
          { "matcher": { "id": "byName", "options": "HTTP 4xx" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }] },
          { "matcher": { "id": "byName", "options": "HTTP 5xx" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }] }
        ]
      }
    },

    {
      "id": 31,
      "title": "Latency Percentiles — p50 · p95 · p99",
      "description": "HTTP response time distribution: median, 95th, and 99th percentiles",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p50", "refId": "A", "instant": false, "range": true },
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p95", "refId": "B", "instant": false, "range": true },
        { "datasource": { "type": "prometheus", "uid": "ffgx1hbr25a0wc" }, "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p99", "refId": "C", "instant": false, "range": true }
      ],
      "gridPos": { "x": 14, "y": 17, "w": 10, "h": 9 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"], "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "off" }
          }
        },
