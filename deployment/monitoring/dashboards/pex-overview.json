      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{job=\"pex-api\",status=~\"5..\"}[$__rate_interval])) or vector(0)) / clamp_min(sum(rate(http_requests_total{job=\"pex-api\"}[$__rate_interval])), 0.001) * 100",
