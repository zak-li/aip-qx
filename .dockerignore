# Python build / cache
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage

# Virtualenvs
.venv/
venv/
env/

# Editor / OS state
.vscode/
.idea/
.claude/
*.swp
*.swo

# Git metadata never goes into the image
.git/
.gitignore

# Secrets and certs — must never reach an image layer
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
tests/fixtures/crypto_config_mock/

# Build / packaging artefacts
*.tar.gz
*.pdf
Dockerfile
docker-compose.yml
.dockerignore

# Logs and ad-hoc text dumps
logs/
*.log
*.txt
!requirements.txt

# Anything not needed at runtime
tests/
scripts/
*.sh

# Side modules — built/run independently from this image
stack/
db/
!db/migrations/
chaincode/
fabric/
proto/
