        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"pex-api\"}[$__rate_interval]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "title": "Throughput",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
